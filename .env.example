# Musiva API environment template
# Copy this file to .env and set values as needed.

# Optional: Proxy credentials used by upstream requests.
# Leave empty to disable proxy usage.
PROXY_USERNAME=
PROXY_PASSWORD=

# Optional: Spotify client credentials for /spotify/trending source.
# Leave empty to disable Spotify integration.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Password for /docs, /redoc, /openapi.json Basic Auth.
# If this variable is omitted, app.py falls back to: prakamya05
# Always set your own strong value in production.
DOCS_PASSWORD=your_docs_password_here

# Optional: Disk cache directory for cached API responses.
CACHE_DIR=/tmp/ytm_cache
